# weather-notify 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Discord 配置
DISCORD_CHANNEL_ID=your_channel_id_here
DISCORD_NOTIFY_USER_ID=your_user_id_here
DISCORD_WEBHOOK_URL=your_webhook_url_here

# 发送模式：auto（自动）/ message（仅 message 工具）/ webhook（仅 Webhook）
SEND_MODE=auto

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 城市配置（可选，也可在 config.json 中配置）
CITY_NAME=杭州
CITY_LATITUDE=30.2741
CITY_LONGITUDE=120.1551

# API 配置（可选）
API_TIMEOUT=10
API_RETRY_TIMES=3
